# Copia in .env.local per lo sviluppo locale.
# Su GitHub Pages questi valori vengono popolati dal workflow deploy.yml
# (vedi .github/workflows/deploy.yml).

# Owner del repo — di default viene usato "mramundo"
VITE_GITHUB_OWNER=mramundo

# Nome del repo — di default "goal-quest"
VITE_GITHUB_REPO=goal-quest

# Branch dove risiedono i file JSON (default "main")
VITE_GITHUB_BRANCH=main

# Personal Access Token (fine-grained) con permesso
# Contents: Read and write sul SOLO repo goal-quest.
#
# ATTENZIONE: in questa POC il token viene incluso nel bundle JavaScript.
# Chi ispeziona il sito può estrarlo. Usa un token con scope limitato.
# Per la versione produzione va messo dietro un proxy (Cloudflare Worker,
# Supabase Edge Function, etc).
VITE_GITHUB_TOKEN=

# Opzionale: override del percorso base (usato da GitHub Pages).
# Lascia vuoto per "/goal-quest/". Usa "/" per Vercel/Netlify su dominio root.
# VITE_BASE=/
